# SQL Server
DB_CONNECTION_STRING=Server=localhost\SQLEXPRESS;Database=HotelBookingDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;

# JWT
JWT_SECRET=your-256-bit-secret-minimum-32-characters-long
JWT_ISSUER=HotelBookingAPI
JWT_AUDIENCE=HotelBookingClients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Razorpay
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_CURRENCY=INR

# Email
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=Hotel Booking
EMAIL_FROM_ADDRESS=your-email@gmail.com

# App
APP_ENV=Development
APP_BASE_URL=https://localhost:7001
